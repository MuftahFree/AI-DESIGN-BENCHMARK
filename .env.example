# ============================================================
# Environment Variables — DO NOT commit real values to git.
# Copy this file to .env and fill in your keys:
#   cp .env.example .env
# ============================================================

# Google Gemini API key (used as the primary API_KEY if API_KEY is empty)
GEMINI_API_KEY=

# Explicit override — if set, takes priority over GEMINI_API_KEY
API_KEY=

# OpenRouter API key (for alternative model providers)
OPENROUTER_API_KEY=
